<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow outbound HTTPS to claude.ai -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- NOTE: No app-sandbox here. Sandboxed WKWebView gets a container-isolated
         cookie store instead of the shared Safari store. Without the sandbox,
         WKWebsiteDataStore.default() correctly shares Safari's login session. -->
</dict>
</plist>
